VITE_FIREBASE_API_KEY="TU_NUEVA_CLAVE_API_AQUI"

# Firebase Cloud Messaging (notificaciones push)
# Obtener en: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY="TU_VAPID_KEY_AQUI"

# Secreto para proteger el endpoint /api/notify (pon cualquier string seguro)
VITE_NOTIFY_SECRET="TU_SECRETO_AQUI"

# Variables solo para Vercel (NO para el frontend):
# FIREBASE_SERVICE_ACCOUNT = JSON completo del Service Account (en una sola línea)
# NOTIFY_SECRET = mismo valor que VITE_NOTIFY_SECRET
